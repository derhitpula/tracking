# --- Tipp-Tracker Dashboard hinter Caddy -------------------------------------
# Den Block in deinen bestehenden /etc/caddy/Caddyfile einfügen und Domain anpassen.
# Caddy holt das TLS-Zertifikat automatisch. Das Dashboard ist nur über localhost:8080
# erreichbar (so in docker-compose.yml gebunden) – Caddy proxyt davor.

# Variante A: eigene Subdomain (empfohlen)
# Voraussetzung: DNS-A-Record  tipps.volleyscope.com -> 2.56.98.246
tipps.volleyscope.com {
    encode gzip

    # optional, aber empfohlen: Passwortschutz
    # Hash erzeugen mit:  caddy hash-password
    basic_auth {
        paul DEIN_BCRYPT_HASH_HIER
    }

    reverse_proxy 127.0.0.1:8080
}

# --- Variante B: Unterpfad auf volleyscope.com -------------------------------
# Falls du keine Subdomain anlegen willst: deinen bestehenden volleyscope.com-Block
# in handle-Blöcke umbauen, damit /tipps zum Tracker geht und der Rest zur App:
#
# volleyscope.com {
#     handle_path /tipps* {
#         reverse_proxy 127.0.0.1:8080      # Tracker-Dashboard
#     }
#     handle {
#         reverse_proxy 127.0.0.1:8000      # bestehende App (waitress) – unverändert
#     }
# }
