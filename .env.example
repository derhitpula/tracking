# --- Tipp-Tracker Konfiguration ---------------------------------------------
# API-Football Key (https://dashboard.api-football.com/register, kostenlos).
# Ohne Key wird nur der dünne TheSportsDB-Fallback genutzt.
APIFOOTBALL_KEY=

# Web-Dashboard: AN, aber privat (nur localhost des VPS, kein öffentlicher Zugang).
# Zugriff per SSH-Tunnel (siehe README). NICHT über eine Domain exponiert.
ENABLE_DASHBOARD=true
DASHBOARD_PORT=8080

# Zeitzone
TZ=Europe/Berlin

# Wie oft gesammelt / Ergebnisse geholt werden (Stunden)
COLLECT_EVERY_HOURS=6
RESULTS_EVERY_HOURS=1

# Proxy gegen Cloudflare-Sperren (betmines/footballtips/freetips/protipster).
# Residential-Proxy mit Auth; mehrere komma-getrennt -> zufällige Rotation.
# Format: http://USER:PASS@IP:PORT
# Beispiel:
# PROXY_URL=http://paulbrz:PASS@172.120.69.17:50100,http://paulbrz:PASS@172.120.69.23:50100
PROXY_URL=

# The Odds API – Fallback-Quoten wenn API-Football keine hat (1xBet bevorzugt).
# Kostenlos: 500 Req./Monat. Key: https://the-odds-api.com/
THEODDSAPI_KEY=

# Alternativ FlareSolverr (löst Cloudflare per Browser; braucht Docker). Leer = aus.
# FLARESOLVERR_URL=http://localhost:8191
FLARESOLVERR_URL=
