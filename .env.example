# --- Tipp-Tracker Konfiguration ---------------------------------------------
# API-Football Key (https://dashboard.api-football.com/register, kostenlos).
# Ohne Key wird nur der dünne TheSportsDB-Fallback genutzt.
APIFOOTBALL_KEY=

# Web-Dashboard: standardmäßig AUS (headless, keine URL/kein offener Port).
# Nur einschalten, wenn du es wirklich willst: ENABLE_DASHBOARD=true
# und in docker-compose.yml die ports-Zeile einkommentieren.
ENABLE_DASHBOARD=false
DASHBOARD_PORT=8080

# Zeitzone
TZ=Europe/Berlin

# Wie oft gesammelt / Ergebnisse geholt werden (Stunden)
COLLECT_EVERY_HOURS=6
RESULTS_EVERY_HOURS=1
